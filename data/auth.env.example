# Copy to project root as .env or set in Render / system environment.
# When COPYGEN_AUTH_PASSWORD is set, all /api/* (except auth + health) require login.

COPYGEN_AUTH_USER=admin
COPYGEN_AUTH_PASSWORD=change-me-to-a-strong-password
# Optional; auto-derived from password if omitted
# COPYGEN_AUTH_SECRET=random-long-string-at-least-32-chars
